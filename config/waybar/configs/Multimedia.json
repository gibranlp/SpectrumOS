{
    "layer": "bottom",
    "position": "top",
    "height": 30,
    "spacing": 2,
    "margin-left": 5,
    "margin-right": 5,
    "modules-left": ["pulseaudio", "bluetooth"],
    "modules-center": ["custom/media-prev", "custom/media-play-pause", "custom/media", "custom/media-next", "custom/cava"],
    "modules-right": ["backlight", "battery", "clock", "tray"],
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}%",
        "format-bluetooth-muted": "σΑùü {icon}",
        "format-muted": "σΑùü {volume}%",
        "format-icons": {
            "headphone": "σΑ΄΄",
            "hands-free": "σΑ΄é",
            "headset": "σΑ΄é",
            "phone": "σΑè≤",
            "portable": "σΑè≤",
            "car": "σΑ³΄",
            "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
        },
        "on-click": "/usr/share/spectrumos/scripts/SOS_Audio.sh",
        "on-click-middle": "pavucontrol"
    },
    "bluetooth": {
        "format": "σΑ²· {status}",
        "format-disabled": "σΑ²≤",
        "format-off": "σΑ²≤",
        "format-on": "σΑ²°",
        "format-connected": "σΑ²± {device_alias}",
        "format-connected-battery": "σΑ²± {device_alias} {device_battery_percentage}%",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
        "on-click": "blueman-manager"
    },
    "custom/media-prev": {
        "format": "σΑ£°",
        "on-click": "playerctl previous",
        "tooltip": false
    },
    "custom/media-play-pause": {
        "format": "{icon}",
        "return-type": "json",
        "exec": "$HOME/.config/waybar/scripts/mediaplayer.py 2> /dev/null",
        "on-click": "playerctl play-pause",
        "format-icons": {
            "Playing": "σΑèΛ",
            "Paused": "σΑêä"
        }
    },
    "custom/media-next": {
        "format": "σΑ£≠",
        "on-click": "playerctl next",
        "tooltip": false
    },
    "custom/media": {
        "format": "{icon} {text}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "οÜΦ",
            "default": "σΑùö"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/scripts/mediaplayer.py 2> /dev/null",
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl stop",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "smooth-scrolling-threshold": 1,
        "interval": 2
    },
    "custom/cava": {
        "exec": "$HOME/.config/waybar/scripts/waybar-cava.sh",
        "format": "{}"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["σΑÉû", "σΑÉü", "σΑÉ†"],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-"
    },
    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "interval": 10,
        "format": "{icon} {capacity}%",
        "format-charging": "σΑ²³ {capacity}%",
        "format-plugged": "σΑöΞ {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
        "tooltip-format": "{timeTo}, {capacity}%\n{power}W"
    },
    "clock": {
        "format": "σΑΞî {:%H:%M}",
        "format-alt": "σΑÉ≠ {:%A, %B %d, %Y (%R)}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        }
    },
    "tray": {
        "spacing": 10
    }
}
