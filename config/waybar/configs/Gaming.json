{
    "layer": "bottom",
    "position": "top",
    "height": 30,
    "spacing": 2,
    "margin-left": 5,
    "margin-right": 5,
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["hyprland/window", "cpu", "memory", "custom/gpu", "temperature", "custom/fps", "network"],
    "modules-right": ["pulseaudio", "idle_inhibitor", "clock", "tray"],
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "َ°«ƒ",
            "2": "َ°«„",
            "3": "َ°«…",
            "4": "َ°«†",
            "5": "َ°«‡",
            "6": "َ°«ˆ"
        },
        "persistent-workspaces": {
            "DP-1": [1, 2, 3, 4, 5],
            "HDMI-A-1": [6]
        }
    },
    "hyprland/window": {
        "format": "َ°ٹ´ {}",
        "max-length": 30,
        "separate-outputs": true
    },
    "cpu": {
        "interval": 2,
        "format": "َ°»  {usage}%",
        "tooltip": true,
        "on-click": "kitty -e btop"
    },
    "memory": {
        "interval": 2,
        "format": "َ°چ› {percentage}%",
        "tooltip": true,
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "on-click": "kitty -e btop"
    },
    "custom/gpu": {
        "exec": "$HOME/.config/waybar/scripts/gpu_usage.sh",
        "return-type": "json",
        "interval": 2,
        "tooltip": true
    },
    "custom/fps": {
        "exec": "$HOME/.config/waybar/scripts/fps_counter.sh",
        "return-type": "json",
        "interval": 1,
        "tooltip": true
    },
    "temperature": {
        "critical-threshold": 80,
        "interval": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
        "format": "{icon} {temperatureC}آ°C",
        "format-icons": ["ï‹‹", "ï‹ٹ", "ï‹‰", "ï‹ˆ", "ï‹‡"],
        "tooltip": true
    },
    "network": {
        "interval": 2,
        "format-wifi": "َ°–© {bandwidthDownBits}",
        "format-ethernet": "َ°ˆ€ {bandwidthDownBits}",
        "format-linked": "َ°ˆ€ {ifname} (No IP)",
        "format-disconnected": "َ°–ھ Disconnected",
        "tooltip-format": "{ifname} via {gwaddr}\nâ†“ {bandwidthDownBytes} â†‘ {bandwidthUpBytes}",
        "on-click-right": "nm-connection-editor"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}%",
        "format-bluetooth-muted": "َ°‌ں {icon}",
        "format-muted": "َ°‌ں {volume}%",
        "format-icons": {
            "headphone": "َ°‹‹",
            "hands-free": "َ°‹ژ",
            "headset": "َ°‹ژ",
            "phone": "َ°ڈ²",
            "portable": "َ°ڈ²",
            "car": "َ°„‹",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "/usr/share/spectrumos/scripts/SOS_Audio.sh",
        "on-click-middle": "pavucontrol"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "َ°…¶",
            "deactivated": "َ°¾ھ"
        }
    },
    "clock": {
        "format": "َ°¥” {:%H:%M}",
        "format-alt": "َ°ƒ­ {:%A, %B %d, %Y (%R)}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        }
    },
    "tray": {
        "spacing": 10
    }
}
