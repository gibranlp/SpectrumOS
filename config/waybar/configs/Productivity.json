{
    "layer": "bottom",
    "position": "top",
    "height": 30,
    "spacing": 2,
    "margin-left": 5,
    "margin-right": 5,
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["custom/pomodoro"],
    "modules-right": ["network", "pulseaudio", "battery", "clock", "tray"],
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "¾░½ā",
            "2": "¾░½ä",
            "3": "¾░½ģ",
            "4": "¾░½å",
            "5": "¾░½ć",
            "6": "¾░½ł"
        },
        "persistent-workspaces": {
            "DP-1": [1, 2, 3, 4, 5],
            "HDMI-A-1": [6]
        }
    },
    "hyprland/window": {
        "max-length": 30,
        "separate-outputs": true
    },
    "custom/pomodoro": {
        "exec": "$HOME/.config/waybar/scripts/pomodoro.py",
        "return-type": "json",
        "interval": 1,
        "on-click": "$HOME/.config/waybar/scripts/pomodoro.py toggle",
        "on-click-right": "$HOME/.config/waybar/scripts/pomodoro.py tasks",
        "on-click-middle": "$HOME/.config/waybar/scripts/pomodoro.py reset"
    },
    "network": {
        "interval": 5,
        "format-wifi": "¾░¢® {signalStrength}%",
        "format-ethernet": "¾░łĆ {bandwidthDownBytes}",
        "format-linked": "¾░łĆ {ifname} (No IP)",
        "format-disconnected": "¾░¢¬ Disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "tooltip-format": "{ifname} via {gwaddr}\nŌåō {bandwidthDownBytes} Ōåæ {bandwidthUpBytes}",
        "on-click-right": "nm-connection-editor"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}%",
        "format-bluetooth-muted": "¾░Ø¤ {icon}",
        "format-muted": "¾░Ø¤ {volume}%",
        "format-icons": {
            "headphone": "¾░ŗŗ",
            "hands-free": "¾░ŗÄ",
            "headset": "¾░ŗÄ",
            "phone": "¾░Å▓",
            "portable": "¾░Å▓",
            "car": "¾░äŗ",
            "default": ["¾░Ģ┐", "¾░¢Ć", "¾░ĢŠ"]
        },
        "on-click": "/usr/share/spectrumos/scripts/SOS_Audio.sh",
        "on-click-middle": "pavucontrol"
    },
    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "interval": 10,
        "format": "{icon} {capacity}%",
        "format-charging": "¾░éä {capacity}%",
        "format-plugged": "¾░Üź {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éĆ", "¾░éü", "¾░éé", "¾░ü╣"],
        "tooltip-format": "{timeTo}, {capacity}%\n{power}W"
    },
    "clock": {
        "format": "¾░źö {:%H:%M}",
        "format-alt": "¾░āŁ {:%A, %B %d, %Y (%R)}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        }
    },
    "tray": {
        "spacing": 10
    }
}
