{
    "layer": "bottom",
    "position": "top",
    "height": 30,
    "spacing": 2,
    "margin-left": 5,
    "margin-right": 5,
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["custom/weather", "disk", "cpu", "memory", "custom/gpu", "temperature", "network", "pulseaudio", "backlight", "battery", "idle_inhibitor", "tray"],
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "ůįęÉ",
            "2": "ůįęĄ",
            "3": "ůįęÖ",
            "4": "ůįęÜ",
            "5": "ůįęá",
            "6": "ůįęą"
        },
        "persistent-workspaces": {
            "DP-1": [1, 2, 3, 4, 5],
            "HDMI-A-1": [6]
        }
    },
    "hyprland/window": {
        "max-length": 40,
        "separate-outputs": true
    },
    "custom/weather": {
        "format": "{}",
        "tooltip": true,
        "interval": 1800,
        "exec": "$HOME/.config/waybar/scripts/weather.sh",
        "return-type": "json"
    },
    "disk": {
        "interval": 30,
        "format": "ůįčä {percentage_used}%",
        "path": "/"
    },
    "cpu": {
        "interval": 5,
        "format": "ůįĽ† {usage}%",
        "tooltip": true,
        "on-click": "kitty -e btop"
    },
    "memory": {
        "interval": 5,
        "format": "ůįćõ {}%",
        "tooltip": true,
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "on-click": "kitty -e btop"
    },
    "custom/gpu": {
        "exec": "$HOME/.config/waybar/scripts/gpu_usage.sh",
        "return-type": "json",
        "interval": 5,
        "tooltip": true
    },
    "temperature": {
        "critical-threshold": 80,
        "interval": 5,
        "format": "{icon} {temperatureC}¬įC",
        "format-icons": ["Ôčč", "Ôčä", "ÔčČ", "Ôčą", "Ôčá"],
        "tooltip": true
    },
    "network": {
        "interval": 5,
        "format-wifi": "ůįĖ© {signalStrength}%",
        "format-ethernet": "ůįąÄ {bandwidthDownBytes}",
        "format-linked": "ůįąÄ {ifname} (No IP)",
        "format-disconnected": "ůįĖ™ Disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "tooltip-format": "{ifname} via {gwaddr}\n‚Üď {bandwidthDownBytes} ‚ÜĎ {bandwidthUpBytes}",
        "on-click-right": "nm-connection-editor"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}%",
        "format-bluetooth-muted": "ůįĚü {icon}",
        "format-muted": "ůįĚü {volume}%",
        "format-icons": {
            "headphone": "ůįčč",
            "hands-free": "ůįčé",
            "headset": "ůįčé",
            "phone": "ůįŹ≤",
            "portable": "ůįŹ≤",
            "car": "ůįĄč",
            "default": ["ůįēŅ", "ůįĖÄ", "ůįēĺ"]
        },
        "on-click": "/usr/share/spectrumos/scripts/SOS_Audio.sh",
        "on-click-middle": "pavucontrol"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["ůįÉě", "ůįÉü", "ůįÉ†"],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-"
    },
    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "interval": 10,
        "format": "{icon} {capacity}%",
        "format-charging": "ůįāĄ {capacity}%",
        "format-plugged": "ůįö• {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["ůįāé", "ůįĀļ", "ůįĀĽ", "ůįĀľ", "ůįĀĹ", "ůįĀĺ", "ůįĀŅ", "ůįāÄ", "ůįāĀ", "ůįāā", "ůįĀĻ"],
        "tooltip-format": "{timeTo}, {capacity}%\n{power}W"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ůįÖ∂",
            "deactivated": "ůįĺ™"
        }
    },
    "clock": {
        "format": "ůį•Ē {:%H:%M}",
        "format-alt": "ůįÉ≠ {:%A, %B %d, %Y (%R)}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        }
    },
    "tray": {
        "spacing": 10
    }
}
