{
    "layer": "bottom",
    "position": "top",
    "height": 30,
    "spacing": 5,
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["custom/weather", "disk", "cpu", "memory", "temperature", "network", "pulseaudio", "backlight", "battery", "idle_inhibitor", "tray"],
    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "σΑΪÉ",
            "2": "σΑΪ³",
            "3": "σΑΪÖ",
            "4": "σΑΪÜ",
            "5": "σΑΪ΅",
            "6": "σΑΪà",
            "todoist": "νö€",
            "obsidian": "σ±û¹"
        },
        "persistent-workspaces": {
            "*": 6
        }
    },
    "hyprland/window": {
        "max-length": 40,
        "separate-outputs": true
    },
    "custom/weather": {
        "format": "{}",
        "tooltip": true,
        "interval": 1800,
        "exec": "$HOME/.config/waybar/scripts/weather.sh",
        "return-type": "json"
    },
    "disk": {
        "interval": 30,
        "format": "σΑ΄ä {percentage_used}%",
        "path": "/"
    },
    "cpu": {
        "interval": 5,
        "format": "σΑΜ† {usage}%",
        "tooltip": true,
        "on-click": "kitty -e btop"
    },
    "memory": {
        "interval": 5,
        "format": "σΑç¦ {}%",
        "tooltip": true,
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "on-click": "kitty -e btop"
    },
    "temperature": {
        "critical-threshold": 80,
        "interval": 5,
        "format": "{icon} {temperatureC}¬ΑC",
        "format-icons": ["", "", "", "", ""],
        "tooltip": true
    },
    "network": {
        "interval": 5,
        "format-wifi": "σΑ•© {signalStrength}%",
        "format-ethernet": "σΑàÄ {bandwidthDownBytes}",
        "format-linked": "σΑàÄ {ifname} (No IP)",
        "format-disconnected": "σΑ•Σ Disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "tooltip-format": "{ifname} via {gwaddr}\nβÜ™ {bandwidthDownBytes} βÜë {bandwidthUpBytes}",
        "on-click-right": "nm-connection-editor"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}%",
        "format-bluetooth-muted": "σΑùü {icon}",
        "format-muted": "σΑùü {volume}%",
        "format-icons": {
            "headphone": "σΑ΄΄",
            "hands-free": "σΑ΄é",
            "headset": "σΑ΄é",
            "phone": "σΑè≤",
            "portable": "σΑè≤",
            "car": "σΑ³΄",
            "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
        },
        "on-click": "pavucontrol"
    },
    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "interval": 10,
        "format": "{icon} {capacity}%",
        "format-charging": "σΑ²³ {capacity}%",
        "format-plugged": "σΑöΞ {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
        "tooltip-format": "{timeTo}, {capacity}%\n{power}W"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["σΑÉû", "σΑÉü", "σΑÉ†"],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "σΑÖΕ",
            "deactivated": "σΑΨΣ"
        }
    },
    "clock": {
        "format": "σΑΞî {:%H:%M}",
        "format-alt": "σΑÉ≠ {:%A, %B %d, %Y (%R)}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "days": "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        }
    },
    "tray": {
        "spacing": 10
    }
}