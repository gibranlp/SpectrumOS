[global]
    monitor = 0
    follow = none
    width = (0, 450)
    height = (50, 200)
    origin = top-right
    offset = (10, 10)
    scale = 0
    notification_limit = 5
    
    # Progress bar configuration
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 2
    progress_bar_min_width = 100
    progress_bar_max_width = 400
    progress_bar_corner_radius = 2
    
    indicate_hidden = yes
    transparency = 0
    separator_height = 0
    padding = 8
    horizontal_padding = 8
    text_icon_padding = 5
    frame_width = 3
    frame_color = "{color0}"
    gap_size = 6
    separator_color = auto
    sort = yes
    idle_threshold = 120
    
    # Font and text configuration
    font = Courier Prime Medium 14.5
    line_height = 2
    markup = full
    format = "🔔 <b>%s</b>\n%b\n%p"
    alignment = left
    vertical_alignment = center
    show_age_threshold = -1
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = true
    show_indicators = yes
    
    # Icon configuration
    icon_position = left
    min_icon_size = 40
    max_icon_size = 150
    icon_path = /usr/share/icons/gnome/16x16/status/:/usr/share/icons/gnome/16x16/devices/
    
    # History and interaction
    sticky_history = yes
    history_length = 30
    dmenu = /usr/bin/rofi -dmenu -p "Notifications:"
    browser = /usr/bin/xdg-open
    always_run_script = true
    
    # Window properties
    title = Dunst
    class = Dunst
    corner_radius = 8
    ignore_dbusclose = false
    force_xwayland = false
    force_xinerama = false
    
    # Mouse actions
    mouse_left_click = do_action, close_current
    mouse_middle_click = close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = true

[urgency_low]
    background = "{color1}"
    foreground = "{color0}"
    frame_color = "{color0}"
    timeout = 6
    format = "🔔 <b>%s</b>\n%b"
    default_icon = /usr/share/icons/hicolor/48x48/status/dialog-information.png

[urgency_normal]
    background = "{color3}"
    foreground = "{color0}"
    frame_color = "{color0}"
    timeout = 10
    format = "🔔 <b>%a\n%s</b>\n%b"
    highlight = "{color0}"
    default_icon = /usr/share/icons/hicolor/48x48/status/dialog-information.png

[urgency_critical]
    background = "{color1}"
    foreground = "{color15}"
    frame_color = "{color9}"
    timeout = 0
    format = "🚨 <b>%s</b>\n%b"
    default_icon = /usr/share/icons/hicolor/48x48/status/dialog-warning.png

